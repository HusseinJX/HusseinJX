<table id="basic-datatable" class="table table-bordered table-striped">
                  <thead>
                  <tr>
                    <th>Name</th>
                    <th>Details</th>
                    <th>Cost</th>
                    <th>Price</th>
                    <th>Inventory</th>
                    <th>Options</th>
                  </tr>
                  </thead>
                  <tbody>
                      {{#each products}}
                      <tr>
                          <td>{{product}}</td>
                          <td>{{details}}</td>
                          <td>{{cost}}</td>
                            <td>{{price}}</td>
                            <td>{{inventory}}</td>
                          <td>
                            <a href="javascript:void(0);" onclick="rightModal('/products/edit/{{id}}','update product');">edit</a>
                            <a href="javascript:void(0);" onclick="confirmModal('/products/del/{{id}}', showProducts)">del</a>
                          </td>

                      </tr>
                      {{/each}}
                  </tbody>
                </table>
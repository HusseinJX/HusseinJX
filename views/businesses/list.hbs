<table id="basic-datatable" class="table table-bordered table-striped">
                  <thead>
                  <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Contact Name</th>
                    <th>Options</th>
                  </tr>
                  </thead>
                  <tbody>
                      {{#each business_list}}
                      <tr>
                          <td>{{name}}</td>
                          <td>{{email}}</td>
                          <td>{{phone}}</td>
                          <td>{{address}}</td>
                          <td>{{contact_name}}</td>
                          <td>
                            <a href="javascript:void(0);" onclick="rightModal('/businesses/edit/{{id}}','update user');">edit  </a>
                            <a href="javascript:void(0);" onclick="confirmModal('/businesses/del/{{id}}', showUsers)">del</a>
                          </td>

                      </tr>
                      {{/each}}
                  </tbody>
                </table>